# Copy this file to .env.test.local and fill in your values
# .env.test.local is gitignored — never commit real credentials

# Supabase Dev project (same as .env.local)
VITE_SUPABASE_URL=https://your-dev-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# E2E test user (created in Supabase Auth with password enabled)
E2E_TEST_EMAIL=test@nema-app.dev
E2E_TEST_PASSWORD=your-secure-password

# Optional: override default dev server URL
# E2E_BASE_URL=http://localhost:5173
